# -- Django --
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# -- Database --
DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/ielts_dev

# -- CORS (FE origins) --
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# API base path is /api/v1/ (FE points its VITE_API_BASE_URL there)

# -- Multi-tenancy --
TENANT_DEFAULT_SLUG=default
TENANT_RESOLVE_FROM_SUBDOMAIN=False

# -- Gemini provider (dev: AI Studio) --
USE_VERTEX_AI=False
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-2.5-flash
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-09-2025

# -- Vertex AI (prod only — set on Railway, never commit) --
# USE_VERTEX_AI=True
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GCP_REGION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...single line...}
